AIRFLOW_CONFIG=/opt/airflow/config/airflow.cfg

# API_AUTH
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# Celery
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://<username>:<password>@postgres/<db-name>
AIRFLOW__CELERY_BROKER_TRANSPORT_OPTIONS__VISIBILITY_TIMEOUT=21600

# Common IO
AIRFLOW__COMMON_IO__XCOM_OBJECTSTORAGE_PATH=s3://garage_s3/airflow/xcom
AIRFLOW__COMMON_IO__XCOM_OBJECTSTORAGE_THRESHOLD=0

# Core
AIRFLOW__CORE__AUTH_MANAGER=airflow.providers.fab.auth_manager.fab_auth_manager.FabAuthManager
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://airflow-apiserver:8080/execution/
AIRFLOW__CORE__FERNET_KEY=<fernet-key>
AIRFLOW__CORE__LOAD_EXAMPLES=true
AIRFLOW__CORE__XCOM_BACKEND=airflow.providers.common.io.xcom.backend.XComObjectStorageBackend

# Database
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://<username>:<password>@postgres/<db-name>

# Logging
AIRFLOW__LOGGING__DELETE_LOCAL_LOGS=true
AIRFLOW__LOGGING__JSON_LOGS=true
AIRFLOW__LOGGING__REMOTE_LOGGING=true
AIRFLOW__LOGGING__REMOTE_BASE_LOG_FOLDER=s3://airflow/logs
AIRFLOW__LOGGING__REMOTE_LOG_CONN_ID=garage_s3

# Metrics
AIRFLOW__METRICS__STATSD_ON=true
AIRFLOW__METRICS__STATSD_HOST=statsd-exporter
AIRFLOW__METRICS__STATSD_PORT=8125
AIRFLOW__METRICS__STATSD_PREFIX=airflow

# Webserver
AIRFLOW__WEBSERVER__SECRET_KEY=<secret-key>

# Connections
AIRFLOW_CONN_GARAGE_S3=s3://<key-id>:<secret-key>@garage:3900/?endpoint_url=http%3A%2F%2Fgarage%3A3900&region_name=garage
